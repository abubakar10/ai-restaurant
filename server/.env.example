# --- Supabase (recommended) ---
# Dashboard → Connect → ORMs / Prisma → copy the pooled string, OR use Session pooler (port 6543).
# Direct db.*.supabase.co:5432 often fails from local networks; the pooler usually works.
#
# Example (Transaction pooler — replace host, user, password):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# If you must use the direct host:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Pooled (app + Prisma queries) — Supabase pooler :6543
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct (migrations only) — db.PROJECT_REF.supabase.co:5432, user `postgres`
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
