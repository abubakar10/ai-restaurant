generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Pooled URL (e.g. Supabase :6543) — used by the app at runtime
  url       = env("DATABASE_URL")
  /// Direct Postgres URL — required for `prisma db push` / migrations when using a pooler
  directUrl = env("DIRECT_URL")
}

/// Single location for Milestone 1
model Location {
  id   String @id @default(uuid())
  name String
}

enum SupplierKind {
  INTERNAL
  EXTERNAL
}

/// Master supplier list (Milestone 2) — mirrors Google Sheet columns.
model Supplier {
  id                   String           @id @default(uuid())
  code                 String           @unique
  name                 String
  kind                 SupplierKind     @default(EXTERNAL)
  contactPerson        String?
  phone                String?
  contactEmail         String?
  orderingDaysNote     String?
  deliveryDaysNote     String?
  weekendsNote         String?
  /// Business days from order to delivery (weekends excluded from the count).
  leadTimeBusinessDays Int              @default(2)
  ingredients          Ingredient[]
  purchaseOrders       PurchaseOrder[]
}

/// Item master rows (Milestone 2) — mirrors Google Sheet item catalog.
model ItemMaster {
  id                         String   @id @default(uuid())
  itemId                     String   @unique
  itemName                   String
  type                       String
  class                      String
  baseUom                    String
  shelfLifeDays              Int?
  traceBatch                 String?
  barcode                    String?
  isProductionItem           Boolean  @default(false)
  isRecipeIngredient         Boolean  @default(true)
  sourcingMode               String
  productionCapacityPerDay   Decimal? @db.Decimal(14, 6)
  /// Optional link to live ingredient SKU when aligned.
  ingredientInternalNumber   String?  @unique
}

model MenuItem {
  id        String       @id @default(uuid())
  code      String       @unique
  name      String
  colorHex  String?
  sortOrder Int          @default(0)
  recipe    RecipeLine[]
  sales     SalesEntry[]
}

/// Canonical ingredient + stock + vendor snapshot for Phase 1
model Ingredient {
  id               String       @id @default(uuid())
  internalNumber   String       @unique
  name             String
  class            String
  type             String       @default("Food")
  /// PAR — optional reference / alerts (M2 primary driver is forecast + MAPE).
  parLevel         Decimal      @db.Decimal(14, 6)
  /// Stock in inventoryUnit (kg for weight SKUs, each for count)
  onHand           Decimal      @db.Decimal(14, 6)
  inventoryUnit    InventoryUnit
  vendorName       String?
  supplierSku      String?
  minOrder         Decimal?     @db.Decimal(14, 6)
  unitCost         Decimal?     @db.Decimal(14, 4)
  /// e.g. 2 kg per pack
  orderPackAmount  Decimal?     @db.Decimal(14, 6)
  orderPackLabel   String?
  /// Preferred supplier (SupplierITEM / master list).
  supplierId       String?
  supplier         Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  /// When forecast MAPE cannot be computed, use this decimal fraction (e.g. 0.10 = 10%).
  mapeFallbackPct  Decimal?     @db.Decimal(8, 6)
  /// Max inventory-days of cover for ordering (e.g. avocado). Null = no cap.
  shelfLifeDays    Int?
  recipeLines      RecipeLine[]
  poLines          PurchaseOrderLine[]
}

enum InventoryUnit {
  KG
  EACH
}

model RecipeLine {
  id           String      @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  /// Amount in `unit`
  amount       Decimal     @db.Decimal(14, 6)
  unit         RecipeUnit

  @@index([menuItemId])
  @@index([ingredientId])
}

enum RecipeUnit {
  GRAM
  EACH
  KG
}

model SalesEntry {
  id         String   @id @default(uuid())
  soldAt     DateTime @default(now())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity   Int

  @@index([menuItemId])
  @@index([soldAt])
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  poNumber             String              @unique
  status               PurchaseOrderStatus @default(SENT_TO_SUPPLIER)
  /// Supervisor approved / PO created.
  approvedAt           DateTime            @default(now())
  /// When the supplier notification was sent (email).
  sentAt               DateTime?
  /// When the supplier submitted approval on the portal.
  supplierApprovedAt   DateTime?
  /// When the supplier declined.
  supplierDeclinedAt   DateTime?
  /// Unauthenticated supplier portal access (unguessable).
  supplierPortalToken  String?             @unique
  supplierId           String?
  supplier             Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  /// Header note from supplier (portal).
  supplierPoNote       String?
  createdAt            DateTime            @default(now())
  lines                PurchaseOrderLine[]

  @@index([status])
  @@index([approvedAt])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id                   String        @id @default(uuid())
  purchaseOrderId      String
  purchaseOrder        PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId         String
  ingredient           Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  name                 String
  internalNumber       String
  vendorName           String?
  inventoryUnit        InventoryUnit
  /// AI-suggested qty (locked after supervisor approval).
  suggestedQty         Decimal       @db.Decimal(14, 6)
  /// Supervisor-approved qty sent to supplier (locked).
  approvedQty          Decimal       @db.Decimal(14, 6)
  /// Supplier-confirmed qty after portal (null until supplier submits).
  supplierConfirmedQty Decimal?      @db.Decimal(14, 6)
  supplierLineNote     String?
  /// Supervisor receiving confirmation.
  receivedQty          Decimal?      @db.Decimal(14, 6)
  receivingNote        String?
  unitCost             Decimal?      @db.Decimal(14, 4)
  createdAt            DateTime      @default(now())

  @@index([purchaseOrderId])
  @@index([ingredientId])
}

enum PurchaseOrderStatus {
  /// Legacy rows (pre–supplier portal); treat like supplier-approved for receiving.
  APPROVED
  /// Email sent to supplier; awaiting portal response.
  SENT_TO_SUPPLIER
  /// Supplier confirmed (possibly with qty changes).
  SUPPLIER_APPROVED
  SUPPLIER_DECLINED
  /// Goods received and inventory updated.
  RECEIVED
  CANCELLED
}
