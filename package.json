{
  "name": "ai-restaurant",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:api": "npm run dev -w server",
    "dev:web": "npm run dev -w client",
    "build": "npm run build -w server && npm run build -w client",
    "db:generate": "npm run db:generate -w server",
    "db:push": "npm run db:push -w server",
    "db:seed": "npm run db:seed -w server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "workspaces": [
    "server",
    "client"
  ]
}
